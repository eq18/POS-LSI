   <query>SELECT Urutan_Ke FROM (&#xd;
    SELECT &#xd;
        postransactionheader_code,&#xd;
        ROW_NUMBER() OVER (&#xd;
            ORDER BY postransactionheader_StartTime ASC, postransactionheader_code ASC&#xd;
        ) AS Urutan_Ke&#xd;
    FROM [dbo].[POSTransaction_header]&#xd;
    WHERE postransactionheader_StartTime >= CAST(GETDATE() AS DATE)&#xd;
) x&#xd;
WHERE x.postransactionheader_code = '${nomorTransaksi}'</query>
