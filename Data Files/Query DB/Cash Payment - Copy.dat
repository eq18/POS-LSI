   <query>SELECT DISTINCT a.postransactionheader_ID, c.postransactiondetail_UnitValue, c.postransactiondetail_Qty, c.product_Code, b.PromoCode, b.Discount,c.postransactiondetail_LineTotalAmount, &#xd;
a.postransactionheader_EndTime&#xd;
FROM POSTransaction_header a &#xd;
inner join POSTransactionDiscount b ON a.postransactionheader_ID = b.postransactionheader_ID &#xd;
inner join POSTransaction_detail c on a.postransactionheader_ID = c.postransactionheader_ID&#xd;
inner join POSTransactionPayment d ON a.postransactionheader_ID = d.postransactionheader_ID&#xd;
inner join POSTransactionDiscountSAP e on a.postransactionheader_ID = d.postransactionheader_ID&#xd;
where d.postransactionpayment_starttime>'2026-05-25 09:08:33.017'&#xd;
ORDER BY a.postransactionheader_EndTime DESC</query>
